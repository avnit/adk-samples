# Copy to `.env` and fill in real values to run agent.py against a real
# authorization server. The demo and tests do NOT need any of these -- they use
# the bundled mock OAuth2 server.

# --- Shared (both flows) ---
OAUTH_TOKEN_URL="https://auth.example.com/oauth/token"
OAUTH_CLIENT_ID="your-client-id"
OAUTH_CLIENT_SECRET="your-client-secret"
OAUTH_SCOPE="read:findings read:profile"

# --- 2-legged (client_credentials) only ---
# Some providers (e.g. Wiz) require an audience.
OAUTH_AUDIENCE="wiz-api"

# --- 3-legged (authorization_code) only ---
OAUTH_AUTHORIZATION_URL="https://auth.example.com/oauth/authorize"
OAUTH_REDIRECT_URI="https://your-app.example.com/oauth/callback"
